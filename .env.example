# Copy this file to .env and fill in your values.
# Spring Boot: run `export $(grep -v '^#' .env | xargs) && ./mvnw spring-boot:run`
# Or set these in your IDE run configuration.
# On Hugging Face Spaces, set these as Space "Secrets" / "Variables" instead.

# App. On HF Spaces this is your Space URL, e.g. https://<user>-sg-links.hf.space
APP_BASE_URL=http://localhost:8080

# Port the app listens on. Local: 8080. HF Spaces: 7860 (the Dockerfile defaults to 7860).
PORT=8080

# JWT signing key. Any random string of 32+ characters.
JWT_SECRET=change-me-use-a-long-random-secret-in-production

# AI slug suggestions (the AI button). Set at least one to enable it.
OPENAI_API_KEY=        # primary, gpt-4o-mini
ANTHROPIC_API_KEY=     # fallback, claude-haiku

# PostgreSQL. Local defaults match docker-compose.yml.
# For Neon (free managed Postgres) copy host/db/user/password from the Neon dashboard
# and set PGSSLMODE=require (Neon only accepts SSL connections).
PGHOST=localhost
PGPORT=5432
PGDATABASE=urlshortener
PGUSER=postgres
PGPASSWORD=postgres
PGSSLMODE=disable

# Redis. Local docker uses redis://. For Upstash (free managed Redis) use the
# rediss:// TLS URL from the Upstash dashboard, e.g.
# rediss://default:<password>@<region>.upstash.io:6379
REDIS_URL=redis://localhost:6379
