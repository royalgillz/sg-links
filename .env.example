# Copy this file to .env and fill in your values.
# Spring Boot: run `export $(grep -v '^#' .env | xargs) && ./mvnw spring-boot:run`
# Or set these in your IDE run configuration.

# App
APP_BASE_URL=http://localhost:8080

# JWT — any random string of 32+ characters
JWT_SECRET=change-me-use-a-long-random-secret-in-production

# AI slug suggestions (✨ button) — set at least one
OPENAI_API_KEY=        # primary (gpt-4o-mini)
ANTHROPIC_API_KEY=     # fallback (claude-haiku)

# PostgreSQL — matches docker-compose.yml defaults
PGHOST=localhost
PGPORT=5432
PGDATABASE=urlshortener
PGUSER=postgres
PGPASSWORD=postgres

# Redis — matches docker-compose.yml defaults
REDIS_URL=redis://localhost:6379
